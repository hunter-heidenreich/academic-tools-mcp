# OpenAlex API configuration
# Get a free API key at https://openalex.org/settings/api
OPENALEX_API_KEY=
OPENALEX_MAILTO=

# Crossref API configuration
# Provide a mailto email to use the polite pool (higher rate limits)
# See https://www.crossref.org/documentation/retrieve-metadata/rest-api/
CROSSREF_MAILTO=

# Wikipedia API configuration
# Email for the User-Agent header (required by Wikimedia policy)
WIKIPEDIA_MAILTO=

# PDF-to-markdown conversion (optional — only needed for paper PDF pipeline)
# Named backends: "mineru" (default), "marker"
# Custom: any command template with {input} and {output_dir} placeholders
#   e.g. PDF_CONVERTER=my-tool --in "{input}" --out "{output_dir}"
PDF_CONVERTER=mineru
# Optional: path to a virtualenv to activate before running the converter
# PDF_CONVERTER_VENV=~/.venvs/mineru
